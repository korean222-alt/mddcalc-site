# 이 파일은 "어떤 값이 필요한지" 보여주는 예시일 뿐입니다.
# 실제 값은 이 파일에 적지 말고, Vercel 대시보드 > Project Settings > Environment Variables 에만 입력하세요.

DATABASE_URL=mysql://user:password@host:4000/dbname?ssl=...
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# 아래 둘은 선택사항입니다 (없어도 사이트는 정상 작동, 문의폼 알림 메일만 안 옴)
RESEND_API_KEY=your_resend_api_key
CONTACT_NOTIFY_EMAIL=you@example.com
